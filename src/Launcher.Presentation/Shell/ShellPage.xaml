<UserControl
    x:Class="Launcher.Presentation.Shell.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="ShellPage_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <NavigationView
            x:Name="NavView"
            Grid.Row="0"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            OpenPaneLength="200"
            SelectionChanged="NavView_SelectionChanged">

            <!-- 面板顶部：用户信息区域 -->
            <NavigationView.PaneHeader>
                <Grid Padding="12,8" MinHeight="48">
                    <!-- 已登录状态 -->
                    <Grid Visibility="{x:Bind ViewModel.IsAuthenticated, Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <PersonPicture Grid.Column="0" Width="32" Height="32" DisplayName="{x:Bind ViewModel.DisplayName, Mode=OneWay}" />
                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind ViewModel.DisplayName, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="登出" Command="{x:Bind ViewModel.LogoutCommand}" FontSize="11" Padding="6,2" VerticalAlignment="Center" />
                    </Grid>
                    <!-- 未登录状态 -->
                    <Button
                        Content="登录 Epic Games"
                        Command="{x:Bind ViewModel.LoginCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Visibility="{x:Bind ViewModel.IsNotAuthenticated, Mode=OneWay}" />
                </Grid>
            </NavigationView.PaneHeader>

            <!-- 主导航项 -->
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Fab 资产库" Tag="FabLibrary">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F1;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="下载管理" Tag="Downloads">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE896;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="引擎版本" Tag="EngineVersions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE74C;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- 底部导航项 -->
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="设置" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="诊断" Tag="Diagnostics">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <!-- 内容区域 Frame -->
            <Frame x:Name="ContentFrame" />

        </NavigationView>

        <!-- 底部状态栏 -->
        <Grid
            Grid.Row="1"
            Height="28"
            Padding="12,0"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 网络状态 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE774;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock
                    x:Name="NetworkStatusText"
                    Text="网络正常"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- 下载速度占位 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock
                    x:Name="DownloadSpeedText"
                    Text=""
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <FontIcon
                    x:Name="DownloadIcon"
                    Glyph="&#xE896;"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Visibility="Collapsed" />
            </StackPanel>
        </Grid>

        <!-- Toast 通知覆盖层（右上角） -->
        <StackPanel
            x:Name="ToastHost"
            Grid.Row="0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,8,16,0"
            MaxWidth="400"
            Spacing="4" />
    </Grid>
</UserControl>
