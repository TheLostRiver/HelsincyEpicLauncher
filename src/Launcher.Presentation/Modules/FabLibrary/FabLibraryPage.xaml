<Page
    x:Class="Launcher.Presentation.Modules.FabLibrary.FabLibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Launcher.Presentation.Modules.FabLibrary"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis" />
        <local:BoolNegationToVisibilityConverter x:Key="BoolNegToVis" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ====== 顶部：标题 + 搜索 + 筛选 ====== -->
        <Grid Grid.Row="0" Padding="36,24,36,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题 + 刷新 -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    Text="Fab 资产库"
                    Style="{StaticResource TitleTextBlockStyle}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock
                        Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        VerticalAlignment="Center" />
                    <TextBlock
                        Text="个资产"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        VerticalAlignment="Center" />
                    <Button
                        Content="&#xE72C;"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="14"
                        Padding="8,6"
                        ToolTipService.ToolTip="刷新"
                        Click="RefreshButton_Click" />
                </StackPanel>
            </Grid>

            <!-- 搜索栏 + 筛选 -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox
                    Grid.Column="0"
                    PlaceholderText="搜索资产..."
                    Text="{x:Bind ViewModel.SearchKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    MaxWidth="400"
                    HorizontalAlignment="Stretch" />

                <ComboBox
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    PlaceholderText="分类"
                    ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                    MinWidth="140"
                    SelectionChanged="CategoryComboBox_SelectionChanged" />

                <ComboBox
                    x:Name="SortComboBox"
                    Grid.Column="2"
                    Margin="8,0,0,0"
                    MinWidth="120"
                    SelectedIndex="0"
                    SelectionChanged="SortComboBox_SelectionChanged">
                    <ComboBoxItem Content="相关度" Tag="Relevance" />
                    <ComboBoxItem Content="最新" Tag="Newest" />
                    <ComboBoxItem Content="评分" Tag="Rating" />
                    <ComboBoxItem Content="价格↑" Tag="PriceLowToHigh" />
                    <ComboBoxItem Content="价格↓" Tag="PriceHighToLow" />
                </ComboBox>
            </Grid>
        </Grid>

        <!-- ====== 加载骨架屏 ====== -->
        <Grid
            Grid.Row="2"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"
            Padding="36,0,36,24">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.SkeletonItems, Mode=OneTime}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        MinItemWidth="220"
                        MinItemHeight="260"
                        MinColumnSpacing="12"
                        MinRowSpacing="12"
                        ItemsStretch="Fill" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="x:Int32">
                        <Grid
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Padding="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="160" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <!-- 骨架缩略图区域 -->
                            <Border Grid.Row="0" CornerRadius="8,8,0,0"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            <!-- 骨架文字区域 -->
                            <StackPanel Grid.Row="1" Padding="12,8" Spacing="6">
                                <Border Height="16" CornerRadius="4"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                                <Border Height="12" Width="100" CornerRadius="4" HorizontalAlignment="Left"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </Grid>

        <!-- ====== 资产网格 ====== -->
        <ScrollViewer
            x:Name="AssetScrollViewer"
            Grid.Row="2"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolNegToVis}}"
            ViewChanged="AssetScrollViewer_ViewChanged">

            <StackPanel>
                <ItemsRepeater
                    x:Name="AssetGrid"
                    ItemsSource="{x:Bind ViewModel.Assets, Mode=OneWay}"
                    Margin="36,0,36,12"
                    ElementPrepared="AssetGrid_ElementPrepared">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MinItemWidth="220"
                            MinItemHeight="280"
                            MinColumnSpacing="12"
                            MinRowSpacing="12"
                            ItemsStretch="Fill" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="local:FabAssetCardViewModel">
                            <Grid
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                Padding="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="160" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- 缩略图 -->
                                <Grid Grid.Row="0">
                                    <Border CornerRadius="8,8,0,0"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                                    <!-- 加载占位 -->
                                    <ProgressRing
                                        IsActive="{x:Bind IsThumbnailLoading, Mode=OneWay}"
                                        Width="24" Height="24"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="{x:Bind IsThumbnailLoading, Mode=OneWay}" />
                                    <!-- 实际缩略图 -->
                                    <Image
                                        Source="{x:Bind Thumbnail, Mode=OneWay}"
                                        Stretch="UniformToFill"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                    <!-- 已拥有标记 -->
                                    <Border
                                        Visibility="{x:Bind IsOwned, Converter={StaticResource BoolToVis}}"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="0,8,0,4"
                                        Padding="6,2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top">
                                        <TextBlock Text="已拥有" FontSize="10" Foreground="White" />
                                    </Border>
                                </Grid>

                                <!-- 信息区 -->
                                <StackPanel Grid.Row="1" Padding="12,8" Spacing="4">
                                    <TextBlock
                                        Text="{x:Bind Title}"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        TextTrimming="CharacterEllipsis"
                                        MaxLines="2"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Text="{x:Bind Author}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextTrimming="CharacterEllipsis" />

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            Text="{x:Bind PriceText}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            FontWeight="SemiBold"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{x:Bind RatingText}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- 加载更多指示器 -->
                <ProgressRing
                    IsActive="{x:Bind ViewModel.IsLoadingMore, Mode=OneWay}"
                    Width="32" Height="32"
                    Margin="0,8,0,24"
                    HorizontalAlignment="Center"
                    Visibility="{x:Bind ViewModel.IsLoadingMore, Mode=OneWay}" />
            </StackPanel>
        </ScrollViewer>

        <!-- ====== 空状态 ====== -->
        <Grid
            Grid.Row="2"
            Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVis}}"
            MinHeight="300"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <FontIcon Glyph="&#xE8F1;" FontSize="48" Foreground="{ThemeResource TextFillColorDisabledBrush}" HorizontalAlignment="Center" />
                <TextBlock
                    Text="未找到资产"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="尝试调整搜索关键词或筛选条件"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorDisabledBrush}"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
