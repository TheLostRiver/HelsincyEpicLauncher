<Page
    x:Class="Launcher.Presentation.Modules.EngineVersions.EngineVersionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Launcher.Presentation.Modules.EngineVersions"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Grid Padding="32,24,32,16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Text="引擎版本"
                FontSize="28"
                FontWeight="SemiBold"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

            <Button
                Grid.Column="1"
                Content="刷新"
                Click="Refresh_Click"
                VerticalAlignment="Center"/>
        </Grid>

        <!-- 加载指示器 -->
        <ProgressRing
            Grid.Row="1"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            Width="48" Height="48"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>

        <!-- 错误提示 -->
        <InfoBar
            Grid.Row="1"
            IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
            Severity="Error"
            Title="加载失败"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            Margin="0,0,0,8"
            VerticalAlignment="Top"/>

        <!-- 主内容 -->
        <ScrollViewer
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto"
            Visibility="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}">

            <StackPanel Spacing="24">

                <!-- 已安装版本区域 -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.HasInstalled, Mode=OneWay}">
                    <TextBlock
                        Text="已安装"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.InstalledVersions, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="local:InstalledEngineItemViewModel">
                                <Grid
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16,12"
                                    ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 引擎图标 -->
                                    <FontIcon
                                        Grid.Column="0"
                                        Glyph="&#xE950;"
                                        FontSize="28"
                                        Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>

                                    <!-- 版本信息 -->
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock
                                            Text="{x:Bind DisplayName}"
                                            FontSize="16"
                                            FontWeight="SemiBold"/>
                                        <TextBlock
                                            Text="{x:Bind InstallPath}"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock
                                                Text="{x:Bind SizeOnDiskText}"
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                            <TextBlock
                                                Text="{x:Bind InstalledAtText}"
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 启动按钮 -->
                                    <Button
                                        Grid.Column="3"
                                        Content="启动"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        Tag="{x:Bind VersionId}"
                                        Click="Launch_Click"
                                        MinWidth="80"/>

                                    <!-- 卸载按钮 -->
                                    <Button
                                        Grid.Column="4"
                                        Content="卸载"
                                        Tag="{x:Bind VersionId}"
                                        Click="Uninstall_Click"
                                        MinWidth="80"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- 可用版本区域 -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.HasAvailable, Mode=OneWay}">
                    <TextBlock
                        Text="可用版本"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.AvailableVersions, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="local:EngineVersionItemViewModel">
                                <Grid
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16,12"
                                    ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 引擎图标 -->
                                    <FontIcon
                                        Grid.Column="0"
                                        Glyph="&#xE896;"
                                        FontSize="28"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>

                                    <!-- 版本信息 -->
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock
                                            Text="{x:Bind DisplayName}"
                                            FontSize="16"
                                            FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock
                                                Text="{x:Bind DownloadSizeText}"
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                            <TextBlock
                                                Text="{x:Bind ReleaseDateText}"
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock
                                            Text="{x:Bind StatusText, Mode=OneWay}"
                                            FontSize="12"
                                            Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                            Visibility="{x:Bind HasStatus, Mode=OneWay}"/>
                                    </StackPanel>

                                    <!-- 已安装标签 -->
                                    <Border
                                        Grid.Column="2"
                                        Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                        CornerRadius="4"
                                        Padding="8,4"
                                        VerticalAlignment="Center"
                                        Visibility="{x:Bind IsInstalled, Mode=OneWay}">
                                        <TextBlock
                                            Text="已安装"
                                            FontSize="12"
                                            Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                    </Border>

                                    <!-- 下载按钮 -->
                                    <Button
                                        Grid.Column="3"
                                        Content="安装"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        Tag="{x:Bind VersionId}"
                                        Click="Download_Click"
                                        IsEnabled="{x:Bind CanDownload, Mode=OneWay}"
                                        MinWidth="80"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- 空状态 -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}">
                    <FontIcon
                        Glyph="&#xE774;"
                        FontSize="48"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        HorizontalAlignment="Center"/>
                    <TextBlock
                        Text="暂无引擎版本数据"
                        FontSize="16"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
