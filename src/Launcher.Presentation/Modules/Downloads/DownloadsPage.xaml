<Page
    x:Class="Launcher.Presentation.Modules.Downloads.DownloadsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Launcher.Presentation.Modules.Downloads"
    Background="Transparent"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <ScrollViewer Padding="36,24,36,24">
        <StackPanel Spacing="8" MaxWidth="960">

            <!-- 页面标题 + 总速度 -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    Text="下载管理"
                    Style="{StaticResource TitleTextBlockStyle}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                            Visibility="{x:Bind ViewModel.HasActiveDownloads, Mode=OneWay}">
                    <FontIcon Glyph="&#xE896;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                    <TextBlock
                        Text="{x:Bind ViewModel.TotalSpeedText, Mode=OneWay}"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                </StackPanel>
            </Grid>

            <!-- 加载指示器 -->
            <ProgressRing
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Width="32" Height="32"
                HorizontalAlignment="Center"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

            <!-- ====== 活跃下载 ====== -->
            <TextBlock
                Text="活跃下载"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Margin="0,0,0,8"
                Visibility="{x:Bind ViewModel.HasActiveDownloads, Mode=OneWay}" />

            <ItemsRepeater
                ItemsSource="{x:Bind ViewModel.Downloads, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.HasActiveDownloads, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="6" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="local:DownloadItemViewModel">
                        <Grid
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="4"
                            Padding="16,12"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 第一行：名称 + 状态文本 + 操作按钮 -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock
                                        Text="{x:Bind AssetName, Mode=OneWay}"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Text="{x:Bind StatusText, Mode=OneWay}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>

                                <!-- 进度数值 -->
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{x:Bind ProgressText, Mode=OneWay}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    VerticalAlignment="Center"
                                    Margin="12,0" />

                                <!-- 操作按钮 -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <Button
                                        Content="&#xE769;"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        FontSize="14"
                                        Padding="8,6"
                                        ToolTipService.ToolTip="暂停"
                                        Visibility="{x:Bind CanPause, Mode=OneWay}"
                                        Tag="{x:Bind TaskId, Mode=OneWay}"
                                        Click="PauseButton_Click" />
                                    <Button
                                        Content="&#xE768;"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        FontSize="14"
                                        Padding="8,6"
                                        ToolTipService.ToolTip="恢复"
                                        Visibility="{x:Bind CanResume, Mode=OneWay}"
                                        Tag="{x:Bind TaskId, Mode=OneWay}"
                                        Click="ResumeButton_Click" />
                                    <Button
                                        Content="&#xE711;"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        FontSize="14"
                                        Padding="8,6"
                                        ToolTipService.ToolTip="取消"
                                        Visibility="{x:Bind CanCancel, Mode=OneWay}"
                                        Tag="{x:Bind TaskId, Mode=OneWay}"
                                        Click="CancelButton_Click" />
                                </StackPanel>
                            </Grid>

                            <!-- 第二行：进度条 -->
                            <ProgressBar
                                Grid.Row="1"
                                Margin="0,8,0,0"
                                Value="{x:Bind ProgressPercent, Mode=OneWay}"
                                Maximum="100"
                                Height="4"
                                CornerRadius="2" />
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- 空状态：无活跃下载 -->
            <Grid
                Visibility="{x:Bind ViewModel.HasActiveDownloads, Mode=OneWay, Converter={StaticResource BoolNegationVisibilityConverter}}"
                MinHeight="200"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <FontIcon Glyph="&#xE896;" FontSize="48" Foreground="{ThemeResource TextFillColorDisabledBrush}" HorizontalAlignment="Center" />
                    <TextBlock
                        Text="暂无活跃下载"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        Text="从 Fab 资产库添加下载任务"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorDisabledBrush}"
                        HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- ====== 下载历史 ====== -->
            <TextBlock
                Text="下载历史"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Margin="0,24,0,8"
                Visibility="{x:Bind ViewModel.HasHistory, Mode=OneWay}" />

            <ItemsRepeater
                ItemsSource="{x:Bind ViewModel.History, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.HasHistory, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="4" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="local:DownloadItemViewModel">
                        <Grid
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="4"
                            Padding="16,10"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Opacity="0.8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock
                                    Text="{x:Bind AssetName, Mode=OneWay}"
                                    Style="{StaticResource BodyTextBlockStyle}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="{x:Bind StatusText, Mode=OneWay}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind ProgressText, Mode=OneWay}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- 底部留白 -->
            <Border Height="24" />
        </StackPanel>
    </ScrollViewer>

    <Page.Resources>
        <local:BoolNegationVisibilityConverter x:Key="BoolNegationVisibilityConverter" />
    </Page.Resources>
</Page>
