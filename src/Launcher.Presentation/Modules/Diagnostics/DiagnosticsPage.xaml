<Page
    x:Class="Launcher.Presentation.Modules.Diagnostics.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Launcher.Presentation.Modules.Diagnostics"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Pivot Margin="16,8,16,8">

        <!-- ====== Tab 1：系统信息 ====== -->
        <PivotItem Header="系统信息">
            <ScrollViewer Padding="0,16,0,16">
                <StackPanel Spacing="8" MaxWidth="800">

                    <!-- 刷新按钮 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.LastRefreshed, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="刷新" Command="{x:Bind ViewModel.RefreshSystemInfoCommand}" />
                    </Grid>

                    <!-- 系统信息卡片 -->
                    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="操作系统" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.OsVersion, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text=".NET 运行时" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.DotNetVersion, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="应用版本" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="运行时长" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Uptime, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    </Grid>

                    <!-- 磁盘空间 -->
                    <TextBlock Text="磁盘空间" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,8" />
                    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="数据目录磁盘" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.DiskUsageText, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>
                            <ProgressBar Value="{x:Bind ViewModel.DiskUsagePercent, Mode=OneWay}" Maximum="100" Height="8" CornerRadius="4" />
                        </StackPanel>
                    </Grid>

                    <!-- 内存 -->
                    <TextBlock Text="内存" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,8" />
                    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="内存使用" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.MemoryUsageText, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    </Grid>

                    <!-- 存储 -->
                    <TextBlock Text="存储" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,8" />
                    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="数据库大小" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.DatabaseSizeMb, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </PivotItem>

        <!-- ====== Tab 2：日志查看器 ====== -->
        <PivotItem Header="日志">
            <Grid Padding="0,16,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 搜索栏 + 筛选 -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        Grid.Column="0"
                        PlaceholderText="搜索日志（关键字 / CorrelationId）"
                        Text="{x:Bind ViewModel.LogSearchKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0,0,8,0" />

                    <ComboBox
                        Grid.Column="1"
                        MinWidth="120"
                        SelectedIndex="{x:Bind ViewModel.SelectedLogLevelIndex, Mode=TwoWay}"
                        Margin="0,0,8,0">
                        <ComboBoxItem Content="全部级别" />
                        <ComboBoxItem Content="Debug" />
                        <ComboBoxItem Content="Info" />
                        <ComboBoxItem Content="Warning" />
                        <ComboBoxItem Content="Error" />
                    </ComboBox>

                    <Button
                        Grid.Column="2"
                        Content="查询"
                        Command="{x:Bind ViewModel.LoadLogsCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Margin="0,0,8,0" />

                    <Button
                        Grid.Column="3"
                        Content="导出"
                        Command="{x:Bind ViewModel.ExportLogsCommand}" />
                </Grid>

                <!-- 日志列表 -->
                <ListView
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.LogEntries}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:LogEntryDisplay">
                            <Grid Padding="4,6" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{x:Bind Timestamp}" FontFamily="Consolas" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Level}" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                           VerticalAlignment="Top" />
                                <TextBlock Grid.Column="2" Text="{x:Bind Source}" FontSize="11" TextTrimming="CharacterEllipsis"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top" />
                                <TextBlock Grid.Column="3" Text="{x:Bind Message}" FontSize="11" TextWrapping="Wrap"
                                           MaxLines="3" VerticalAlignment="Top" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- 底部状态栏 -->
                <Grid Grid.Row="2" Padding="0,8,0,0">
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run Text="共 " /><Run Text="{x:Bind ViewModel.LogCount, Mode=OneWay}" /><Run Text=" 条日志" />
                    </TextBlock>
                </Grid>
            </Grid>
        </PivotItem>

        <!-- ====== Tab 3：缓存管理 ====== -->
        <PivotItem Header="缓存">
            <ScrollViewer Padding="0,16,0,16">
                <StackPanel Spacing="8" MaxWidth="800">

                    <!-- 刷新 + 状态 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.CacheStatusMessage, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="刷新" Command="{x:Bind ViewModel.RefreshCacheCommand}" />
                    </Grid>

                    <!-- 总缓存大小 -->
                    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="总缓存大小" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.TotalCacheSize, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    </Grid>

                    <!-- 缩略图缓存 -->
                    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="缩略图缓存" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind ViewModel.ThumbnailCacheSize, Mode=OneWay}" />
                                <Run Text=" · " />
                                <Run Text="{x:Bind ViewModel.ThumbnailFileCount, Mode=OneWay}" />
                                <Run Text=" 个文件" />
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="2" Content="清理" Command="{x:Bind ViewModel.ClearThumbnailCacheCommand}" Margin="8,0,0,0" />
                    </Grid>

                    <!-- Manifest 缓存 -->
                    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Manifest / 搜索缓存" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind ViewModel.ManifestCacheSize, Mode=OneWay}" />
                                <Run Text=" · " />
                                <Run Text="{x:Bind ViewModel.ManifestFileCount, Mode=OneWay}" />
                                <Run Text=" 个文件" />
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="2" Content="清理" Command="{x:Bind ViewModel.ClearManifestCacheCommand}" Margin="8,0,0,0" />
                    </Grid>

                    <!-- 日志文件 -->
                    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="日志文件" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind ViewModel.LogCacheSize, Mode=OneWay}" />
                                <Run Text=" · " />
                                <Run Text="{x:Bind ViewModel.LogFileCount, Mode=OneWay}" />
                                <Run Text=" 个文件" />
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="2" Content="清理" Command="{x:Bind ViewModel.ClearLogCacheCommand}" Margin="8,0,0,0" />
                    </Grid>

                    <!-- 全部清理 -->
                    <Button
                        Content="清理全部缓存"
                        Command="{x:Bind ViewModel.ClearAllCacheCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0" />

                </StackPanel>
            </ScrollViewer>
        </PivotItem>
    </Pivot>
</Page>
